// Import required libraries
smd (
  {
    pattern: "gpt",
    react: "🤖",
    desc: "Get a response from Bing AI based on user query.",
    category: "ai",
    filename: __filename,
  },
  async (m) => {
    try {
      const userId = m.from; // Unique user ID to track conversations
      const query = m.text.split(' ').slice(1).join(' ');

      if (!query) {
        return await m.send("Please provide a query, e.g., `.gpt What is life?`.");
      }

      // Initialize history for the user if not already present
      if (!conversationHistory[userId]) {
        conversationHistory[userId] = [];
      }

      // Add the user's query to the conversation history
      conversationHistory[userId].push({ from: "user", message: query });

      // Send a loading message
      await m.send("Alya is thinking 🤔");

      // Optionally, send the entire conversation history to the API
      const historyText = conversationHistory[userId].map(entry => entry.message).join('\n');
      const apiUrl = `https://widipe.com/gpt4?text=${encodeURIComponent(historyText)}`;
      const response = await fetch(apiUrl);

      if (!response.ok) {
        return await m.send(`*_Error: ${response.status} ${response.statusText}_*`);
      }

      // Wait for 2 seconds to simulate thinking
      await new Promise(resolve => setTimeout(resolve, 2000));

      // Get the result from the API response
      const data = await response.json();
      const resultText = data.result; // Extract the text from the result part

      // Add the bot's response to the conversation history
      conversationHistory[userId].push({ from: "bot", message: resultText });

      // Format the final message
      const message = `*Response:* \n\n${resultText}`;

      // Send the final response
      await m.send(message);
    } catch (e) {
      await m.error(`${e}\n\ncommand: gpt`, e);
    }
  }
);
