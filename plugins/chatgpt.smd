// Import required libraries
const axios = require('axios');
const { Client, LocalAuth } = require('whatsapp-web.js');

// Your OpenAI API key
const OPENAI_API_KEY = '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';

// Create a new client instance
const client = new Client({
    authStrategy: new LocalAuth(),
});

// Function to send a message to OpenAI and get a response
async function getChatGPTResponse(prompt) {
    try {
        const response = await axios.post('https://api.openai.com/v1/chat/completions', {
            model: 'gpt-3.5-turbo',
            messages: [{ role: 'user', content: prompt }],
        }, {
            headers: {
                'Authorization': `Bearer ${OPENAI_API_KEY}`,
                'Content-Type': 'application/json',
            },
        });

        return response.data.choices[0].message.content.trim();
    } catch (error) {
        console.error('Error fetching response from OpenAI:', error);
        return 'Sorry, I could not fetch a response at the moment.';
    }
}

// Listen for incoming messages
client.on('message', async (msg) => {
    if (msg.body.startsWith('!chatgpt ')) {
        const userPrompt = msg.body.replace('!chatgpt ', '');
        const chatGptResponse = await getChatGPTResponse(userPrompt);
        msg.reply(chatGptResponse);
    }
});

// Client ready event
client.on('ready', () => {
    console.log('Suhail-Md WhatsApp Bot is ready!');
});

// Initialize the WhatsApp client
client.initialize();
